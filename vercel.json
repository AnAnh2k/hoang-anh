{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "(.*)-admin.?"
        }
      ],
      "destination": "/admin/$1"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "(.*)-employer.?"
        }
      ],
      "destination": "/employer/$1"
    }
  ]
}
